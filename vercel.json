{
  "buildCommand": "pnpm --filter @workspace/quantum run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/assets/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
